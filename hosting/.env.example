# PostgreSQL
POSTGRES_USER=localai
POSTGRES_PASSWORD=localai_dev
POSTGRES_DB=localai

# Django
DATABASE_URL=postgresql://localai:localai_dev@postgres:5432/localai
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
CORS_ALLOWED_ORIGINS=http://local-ai.localhost

# RAG service
RAG_API_KEY=dev-rag-key-change-me
RAG_SERVICE_URL=http://rag:8080

# Ollama — default host mode (GPU/Metal). install.sh rewrites these to
# http://ollama:11434 if it falls back to the bundled container.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Backend URL (used by Next.js to reach Django inside Docker)
BACKEND_URL=http://django:8000

# RAG URL (used by Next.js to reach RAG service inside Docker)
RAG_URL=http://rag:8080

# Whisper (offline speech-to-text)
WHISPER_API_KEY=change-me-in-production
WHISPER_MODEL=base

# Docker Hub — pre-built app images
LOCAL_AI_IMAGE_PREFIX=rizwanhameed360s
LOCAL_AI_IMAGE_TAG=1.0.0
# Stable tag for large images (ollama, whisper) that change less often.
# Defaults to LOCAL_AI_IMAGE_TAG if not set.
LOCAL_AI_STABLE_TAG=1.0.0

# Compose profiles. Empty = host Ollama (recommended). install.sh sets this to
# container-ollama only if it falls back to the bundled (CPU-only) container.
COMPOSE_PROFILES=

# Resource caps for bundled Ollama so inference can't freeze Docker / the host.
#   8+ cores / 16GB+ → OLLAMA_CPUS=6, OLLAMA_MEM=8g
#   4 cores / 8GB    → OLLAMA_CPUS=2, OLLAMA_MEM=4g
OLLAMA_CPUS=6
OLLAMA_MEM=6g

# Updater (check-for-updates feature)
UPDATER_SERVICE_URL=http://updater:8070
UPDATER_API_KEY=change-me-in-production
