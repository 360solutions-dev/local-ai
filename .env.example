# Copy to .env and replace ALL placeholder secrets before running:
#   cp .env.example .env
# Generate DJANGO_SECRET_KEY: openssl rand -hex 32
# See docs/INSTALL.md and docs/VERSIONING.md

# PostgreSQL
POSTGRES_USER=localai
POSTGRES_PASSWORD=localai_dev
POSTGRES_DB=localai

# Django
DATABASE_URL=postgresql://localai:localai_dev@postgres:5432/localai
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Shared secret for the RAG service (must match RAG_API_KEY used by Django/Next.js)
RAG_API_KEY=dev-rag-key-change-me

# Service-to-service URLs (used by Django container to reach RAG and Whisper).
# Internal Docker network — service names, not localhost.
RAG_SERVICE_URL=http://rag:8080
WHISPER_SERVICE_URL=http://whisper:8090

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Override to point at an external Ollama instance (e.g. host Ollama on macOS):
#   OLLAMA_HOST=http://host.docker.internal:11434
# Leave blank to use the bundled container (default).
OLLAMA_HOST=http://ollama:11434

# Backend URL (used by Next.js to reach Django)
# Local dev: http://localhost:8000
# Docker:    http://django:8000
BACKEND_URL=http://django:8000

# RAG URL (used by Next.js to reach RAG service inside Docker)
RAG_URL=http://rag:8080

# Whisper (offline speech-to-text)
# Shared secret between Django and the whisper container.
WHISPER_API_KEY=change-me-in-production
# Model size: tiny | base | small (multilingual) or *.en for English-only.
# base ≈ 140 MB, ~1-2s for a 10s clip on Apple Silicon CPU.
WHISPER_MODEL=base

# Docker Hub — pre-built app images (used by docker-compose.release.yml only).
# Create repos on first push: ./scripts/dockerhub-build-push.sh --push
LOCAL_AI_IMAGE_PREFIX=rizwanhameed360s
LOCAL_AI_IMAGE_TAG=1.0.3
# Stable tag for large images (ollama, whisper) that don't change on every release.
# Defaults to LOCAL_AI_IMAGE_TAG if not set.
LOCAL_AI_STABLE_TAG=1.0.3

# Compose profiles — include bundled Ollama container. Remove or clear to use host Ollama (ollama.com).
COMPOSE_PROFILES=container-ollama

# Updater (check-for-updates feature)
UPDATER_SERVICE_URL=http://updater:8070
UPDATER_API_KEY=change-me-in-production
